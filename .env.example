# -----------------------------
# Server-only keys (required)
# -----------------------------
# Never expose these in client-side VITE_* variables.
# Used by /api/claude/messages for AI analysis
CLAUDE_API_KEY=

# Used by /api/gemini/extract for parser AI fallback
GEMINI_API_KEY=

# Required for persistent AI limits/budget (fail-closed policy)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional for cloud sync server routes (/api/cloud/*)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_PUBLIC_ORIGIN=https://labtracker.app

# Optional verified sender overrides for cloud auth emails
LABTRACKER_AUTH_FROM=
LABTRACKER_AUTH_REPLY_TO=
LABTRACKER_SUPPORT_EMAIL=

# Comma-separated allowlist for /api/admin/* access (server-side guard)
LABTRACKER_ADMIN_EMAILS=you@example.com

# Required for encrypted short share links (must decode to exactly 32 bytes)
SHARE_LINK_SECRET_BASE64=

# Public origin used in generated short links
SHARE_PUBLIC_ORIGIN=https://labtracker.app

# Used by /api/parser-improvement/submit for beta parser-improvement emails
RESEND_API_KEY=
LABTRACKER_REPORTS_TO=

# Optional verified sender override for beta parser-improvement emails
LABTRACKER_REPORTS_FROM=

# Optional Sentry server-side error reporting
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Optional Sentry build/source-map upload
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_DASHBOARD_URL=

# -----------------------------
# Client/build flags (optional)
# -----------------------------
# Supabase browser auth + cloud sync (optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Keep false in normal production. Set true only for dev/test troubleshooting.
VITE_ENABLE_PARSER_DEBUG=false

# Dev-only direct Gemini fallback from browser (used in local dev only).
# Do NOT set this in production deployments.
VITE_GEMINI_API_KEY=

# Optional: cap prompt size for AI analysis context (default: 80)
VITE_AI_ANALYSIS_MARKER_CAP=80

# Disable client-side beta usage limits temporarily (debug only)
VITE_DISABLE_BETA_LIMITS=false

# Canonical public origin shown in share-link UI
VITE_SHARE_PUBLIC_ORIGIN=https://labtracker.app

# Optional Sentry browser error reporting
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.12

# -----------------------------
# Optional server guardrails
# -----------------------------
# Disable server-side AI limits/budget checks temporarily (debug only)
AI_LIMITS_DISABLED=false

# Set to 0 to disable budget checks
AI_DAILY_BUDGET_EUR=0
AI_MONTHLY_BUDGET_EUR=0

# Parser AI per-user daily cap (default: 20)
AI_PARSER_MAX_CALLS_PER_USER_PER_DAY=20
