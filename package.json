{
  "name": "labtracker",
  "description": "Privacy-first bloodwork tracking with PDF parsing, trend charts, and AI-powered lab analysis.",
  "homepage": "https://labtracker-dashboard.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/coendeurloo/labtracker.git"
  },
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "vite preview",
    "server:start": "node scripts/server-control.mjs start",
    "server:start:open": "node scripts/server-control.mjs start --open",
    "server:stop": "node scripts/server-control.mjs stop",
    "server:status": "node scripts/server-control.mjs status",
    "parser:scan-examplelabs": "node scripts/parser-batch/scan-examplelabs.mjs",
    "parser:create-fixture-drafts": "node scripts/parser-batch/create-fixture-drafts.mjs",
    "parser:fill-batch-fixtures": "node scripts/parser-batch/fill-batch-fixtures.mjs",
    "parser:batch-report": "PARSER_BATCH_REPORT_WRITE=1 vitest run src/__tests__/parserBatchReport.test.ts",
    "parser:batch-strict": "STRICT_DRAFT_FIXTURES=1 vitest run src/__tests__/parserFixtures.test.ts",
    "app:start": "npm run build && npm run server:start:open",
    "ci:check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.11.17",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.462.0",
    "lz-string": "^1.5.0",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^10.1.0",
    "recharts": "^2.13.0",
    "remark-breaks": "^4.0.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
